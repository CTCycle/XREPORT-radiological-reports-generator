{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XREPORT Desktop",
  "version": "2.3.0",
  "identifier": "com.xreport.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "about:blank"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "XREPORT Desktop",
        "url": "about:blank",
        "width": 1440,
        "height": 920,
        "center": true,
        "resizable": true
      }
    ],
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../server": "app/server",
      "../../scripts": "app/scripts",
      "../../../settings": "settings",
      "../dist": "app/client/dist",
      "../../resources/templates": "app/resources/templates",
      "../../resources/tokenizers/distilbert-base-uncased": "app/resources/tokenizers/distilbert-base-uncased",
      "../../../runtimes/python": "runtimes/python",
      "../../../runtimes/uv": "runtimes/uv",
      "../../../runtimes/nodejs": "runtimes/nodejs"
    }
  }
}
