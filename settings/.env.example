# ============================================================
# Backend Server
# ============================================================
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=5003
RELOAD=false
# Set to true to open a terminal window showing backend logs.
BACKEND_VISIBLE=false

# ============================================================
# Frontend Server
# ============================================================
UI_HOST=127.0.0.1
UI_PORT=8003
VITE_API_BASE_URL=/api
ALWAYS_REBUILD=false

# ============================================================
# Optional Dependencies
# ============================================================
OPTIONAL_DEPENDENCIES=true

# ============================================================
# Database Mode
# ============================================================
# true  = use the embedded SQLite database
# false = use the external PostgreSQL connection below
EMBEDDED_DATABASE=true

# ============================================================
# External Database Connection
# ============================================================
# When provided, DATABASE_URL seeds the host, port, database name, username,
# and password. Explicit DATABASE_* values below override URL parts.
DATABASE_URL=
DATABASE_ENGINE=postgresql+psycopg
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=XREPORT
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=

# ============================================================
# External Database Security And Performance
# ============================================================
DATABASE_SSL=false
DATABASE_SSL_CA=
DATABASE_CONNECT_TIMEOUT=30
DATABASE_INSERT_BATCH_SIZE=1000

# ============================================================
# ML Runtime
# ============================================================
MPLBACKEND=Agg
KERAS_BACKEND=torch

# ============================================================
# Local Inference Providers
# ============================================================
XREPORT_OLLAMA_BASE_URL=http://127.0.0.1:11434
XREPORT_OLLAMA_KEEP_ALIVE=5m
XREPORT_HF_LOCAL_ONLY=true
XREPORT_HF_CACHE_DIR=
XREPORT_HF_MEDGEMMA_REVISION=
XREPORT_INFERENCE_DEVICE=auto
XREPORT_INFERENCE_MAX_LOADED_MODELS=1
XREPORT_INFERENCE_MODEL_TIMEOUT=600
