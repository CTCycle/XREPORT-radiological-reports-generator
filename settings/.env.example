# Application server
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=5003
RELOAD=false
# Set to true to open a terminal window showing backend logs.
BACKEND_VISIBLE=false

# Frontend
UI_HOST=127.0.0.1
UI_PORT=8003
VITE_API_BASE_URL=/api

# Database
XREPORT_DB_BACKEND=sqlite
XREPORT_DATABASE_URL=
XREPORT_DB_ENGINE=postgres
XREPORT_DB_HOST=127.0.0.1
XREPORT_DB_PORT=5432
XREPORT_DB_NAME=XREPORT
XREPORT_DB_USERNAME=postgres
XREPORT_DB_PASSWORD=
XREPORT_DB_SSL=false
XREPORT_DB_SSL_CA=
XREPORT_DB_CONNECT_TIMEOUT=30
XREPORT_DB_INSERT_BATCH_SIZE=1000

# Optional dependencies and ML runtime
OPTIONAL_DEPENDENCIES=true
MPLBACKEND=Agg
KERAS_BACKEND=torch

# Local inference providers
XREPORT_OLLAMA_BASE_URL=http://127.0.0.1:11434
XREPORT_OLLAMA_KEEP_ALIVE=5m
XREPORT_HF_LOCAL_ONLY=true
XREPORT_HF_CACHE_DIR=
XREPORT_HF_MEDGEMMA_REVISION=
XREPORT_INFERENCE_DEVICE=auto
XREPORT_INFERENCE_MAX_LOADED_MODELS=1
XREPORT_INFERENCE_MODEL_TIMEOUT=600
