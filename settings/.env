# ============================================
# Application Server
# ============================================
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=5003
RELOAD=false

# ============================================
# Frontend
# ============================================
UI_HOST=127.0.0.1
UI_PORT=8003
VITE_API_BASE_URL=/api

# ============================================
# Database
# ============================================
# Embedded mode uses the local SQLite database file.
EMBEDDED_DATABASE=true

# Optional full connection URL for external PostgreSQL.
# Component variables below override matching URL parts when both are set.
DATABASE_URL=
DATABASE_ENGINE=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=XREPORT
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=
DATABASE_SSL=false
DATABASE_SSL_CA=
DATABASE_CONNECT_TIMEOUT=30
DATABASE_INSERT_BATCH_SIZE=1000

# ============================================
# Optional Dependencies
# ============================================
OPTIONAL_DEPENDENCIES=true

# ============================================
# ML Runtime
# ============================================
MPLBACKEND=Agg
KERAS_BACKEND=torch
