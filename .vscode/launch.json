{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "cwd": "${workspaceFolder}/app/server",
      "python": "${workspaceFolder}/app/server/.venv/Scripts/python.exe"
    },
    {
      "name": "Debug: Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "server.app:app",
        "--host",
        "127.0.0.1",
        "--port",
        "7690"
      ],
      "jinja": true,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Uvicorn running on (http://\\S+)",
        "uriFormat": "%s/docs"
      },
      "envFile": "${workspaceFolder}/settings/.env",
      "cwd": "${workspaceFolder}/app",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}/app/server/.venv/Scripts/python.exe"
    },
    {
      "name": "Debug: Frontend",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}/app/client",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "start",
        "--",
        "--host",
        "127.0.0.1",
        "--port",
        "4512"
      ],
      "console": "integratedTerminal",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Local:\\s+(http://\\S+)",
        "uriFormat": "%s"
      },
      "autoAttachChildProcesses": false,
      "internalConsoleOptions": "neverOpen",
      "presentation": {
        "hidden": true
      }
    }
  ],
  "compounds": [
    {
      "name": "Debug: Frontend + Backend",
      "configurations": [
        "Debug: Backend",
        "Debug: Frontend"
      ],
      "stopAll": true
    }
  ]
}
