{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XREPORT Desktop",
  "version": "2.1.0",
  "identifier": "com.xreport.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "about:blank"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "XREPORT Desktop",
        "url": "about:blank",
        "width": 1440,
        "height": 920,
        "center": true,
        "resizable": true
      }
    ],
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {
      "../../../pyproject.toml": "pyproject.toml",
      "../../../uv.lock": "uv.lock",
      "../../../XREPORT/server": "XREPORT/server",
      "../../../XREPORT/scripts": "XREPORT/scripts",
      "../../../XREPORT/settings": "XREPORT/settings",
      "../../../XREPORT/resources/templates": "XREPORT/resources/templates",
      "../../../XREPORT/resources/tokenizers/distilbert-base-uncased": "XREPORT/resources/tokenizers/distilbert-base-uncased",
      "../../../XREPORT/resources/runtimes/python": "XREPORT/resources/runtimes/python",
      "../../../XREPORT/resources/runtimes/uv": "XREPORT/resources/runtimes/uv",
      "../../../XREPORT/resources/runtimes/nodejs": "XREPORT/resources/runtimes/nodejs"
    }
  }
}
